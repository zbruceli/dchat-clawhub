{
  "name": "dchat-clawhub",
  "version": "0.1.0",
  "description": "Decentralized bot-to-bot communication over NKN — a ClawHub skill for private, serverless P2P messaging",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dchat-bot": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx tsx tests/e2e-self-echo.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "form-data": "^4.0.5",
    "nkn-sdk": "^1.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
